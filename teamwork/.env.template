# Default worker CLI/model pool; repeat entries to weight selection.
TEAMWORK_WORKER_POOL=copilot:claude-sonnet-4.6@high;copilot:gpt-5.4@high;copilot:gpt-5.4@high;copilot:gemini-3.1-pro-preview@high
# Default mode: solo or pair.
TEAMWORK_MODE=solo
# Max workers when the prompt does not specify a count.
TEAMWORK_MAX_WORKERS=4
# Root for teamwork artifacts/worktrees.
TEAMWORK_OUTPUT_DIR=.teamwork
# Worker message polling interval in seconds.
TEAMWORK_POLL_SECONDS=30
# Singleton teamwork MCP endpoint.
TEAMWORK_MCP_URL=http://127.0.0.1:48741/mcp
# Extra MCP server names worker agents may use in addition to mandatory teamwork MCP. Blank means none.
TEAMWORK_ALLOWED_AGENT_MCPS=
# Skill names worker agents may use. Blank means none.
TEAMWORK_ALLOWED_SKILLS=
# Hours before stale active sessions are abandoned.
TEAMWORK_SESSION_TTL_HOURS=24
# Enable worktree cleanup for terminal sessions.
TEAMWORK_WORKTREE_GC=1

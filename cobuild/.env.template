# Cobuild defaults
COBUILD_OUTPUT_DIR=.cobuild
COBUILD_REQUIRED_APPROVALS=all
COBUILD_ALLOW_HYBRID_FINAL=true
COBUILD_REQUIRE_REBUILD_PASS=true

# Optional fallback roster when SKILL_VARS.roster is omitted.
# Format: alias:cli:model;alias:cli:model;...
COBUILD_DEFAULT_ROSTER=

# Example roster:
# COBUILD_DEFAULT_ROSTER=codex-main:codex:gpt-5;claude-main:claude:claude-sonnet-4-6;gemini-main:gemini:gemini-2.5-pro
